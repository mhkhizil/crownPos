# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@localhost:5432/app_db"

# Supabase (optional — file storage)
# Project URL only (Settings → API → Project URL).
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
# Must be the service_role key (Project Settings → API).
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"
SUPABASE_AVATAR_BUCKET="avatars"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="7d"

# App
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
# When behind a reverse proxy, set to 1 so rate limits use X-Forwarded-For as client IP
# TRUST_PROXY=1

# Email (Brevo SMTP)
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT=587
BREVO_SMTP_USER="your-brevo-smtp-login"
BREVO_SMTP_PASS="your-brevo-smtp-password"
BREVO_FROM_EMAIL="no-reply@example.com"
BREVO_FROM_NAME="App"

# SMS (SMSPoh API v3)
SMSPOH_API_KEY="your-smspoh-v3-api-key"
SMSPOH_API_SECRET="your-smspoh-v3-api-secret"
SMSPOH_SENDER_ID="YourSenderId"

# Pusher (collection reminder live alarms)
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="ap1"
# PUSHER_USE_TLS=true
# Set false to pause the every-minute due-reminder cron (manual dispatch still works)
# COLLECTION_REMINDER_DISPATCH_ENABLED=true

# Root admin (seed)
ROOT_ADMIN_EMAIL="mhkhizilthurainzaw@gmail.com"
ROOT_ADMIN_PASSWORD="root123"
ROOT_ADMIN_NAME="Root Admin"

# `npm run db:seed` always TRUNCATEs all rows in every `public` table (except
# `_prisma_migrations`), then inserts a full relational story covering every
# Prisma model (company → catalog → ops → sales → billing). See docs/seed.md.
# Do not run against a production database unless you intend to wipe all data.
