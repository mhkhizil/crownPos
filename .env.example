# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@localhost:5432/app_db"

# Supabase (optional — file storage)
# Project URL only (Settings → API → Project URL).
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
# Must be the service_role key (Project Settings → API).
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"
SUPABASE_AVATAR_BUCKET="avatars"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="7d"

# App
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
# When behind a reverse proxy, set to 1 so rate limits use X-Forwarded-For as client IP
# TRUST_PROXY=1

# Email (Brevo SMTP)
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT=587
BREVO_SMTP_USER="your-brevo-smtp-login"
BREVO_SMTP_PASS="your-brevo-smtp-password"
BREVO_FROM_EMAIL="no-reply@example.com"
BREVO_FROM_NAME="App"

# SMS (SMSPoh API v3)
SMSPOH_API_KEY="your-smspoh-v3-api-key"
SMSPOH_API_SECRET="your-smspoh-v3-api-secret"
SMSPOH_SENDER_ID="YourSenderId"

# Root admin (seed)
ROOT_ADMIN_EMAIL="admin@example.com"
ROOT_ADMIN_PASSWORD="change-me"
ROOT_ADMIN_PHONE="+959000000000"
ROOT_ADMIN_NICKNAME="Root Admin"

# Optional test client (seed)
# TEST_CLIENT_PHONE="+959111111111"
# TEST_CLIENT_EMAIL="client@example.com"
# TEST_CLIENT_PASSWORD="client-1234"
# TEST_CLIENT_NICKNAME="Test Client"

# `npm run db:seed` always TRUNCATEs all rows in every `public` table (except
# `_prisma_migrations`), then inserts seed users. Schema and migration files are unchanged.
# Do not run against a production database unless you intend to wipe all data.
